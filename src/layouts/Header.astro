---
import { Header as HeaderUI, HeaderActions } from "@/components/ui/header";
import { Logo } from "@/components/ui/logo";
import { Button } from "@/components/ui/button";
import { Icon } from "@/components/ui/icon";
import { ThemeToggle } from "@/components/ui/theme-toggle";
import { site } from "@/config";

const currentPath = Astro.url.pathname;

const links = [
  { label: "Me", href: "/" },
  { label: "Craft", href: "/craft" },
];
---

<HeaderUI class="border-border border-b">
  <Logo href="/" class="flex-1">
    <img src="/favicon.svg" alt={site.name} class="h-8 w-auto" />
  </Logo>

  <nav class="flex items-center justify-center gap-0">
    {
      links.map((link) => {
        const isActive =
          currentPath.replace(/\/$/, "") === link.href.replace(/\/$/, "");
        return (
          <a
            href={link.href}
            aria-current={isActive ? "page" : undefined}
            class:list={[
              "rounded-sm px-2 py-1.5 text-sm transition-colors hover:bg-muted",
              isActive
                ? "bg-muted/50 font-medium text-foreground"
                : "text-muted-foreground",
            ]}
          >
            {link.label}
          </a>
        );
      })
    }
  </nav>

  <HeaderActions class="flex-1 justify-end">
    <Button
      variant="ghost"
      size="icon-sm"
      href={site.links.github}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
    >
      <Icon href={site.links.github} />
    </Button>
    <Button
      variant="ghost"
      size="icon-sm"
      href={site.links.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
    >
      <Icon href={site.links.linkedin} />
    </Button>
    <Button
      variant="ghost"
      size="icon-sm"
      href={site.links.email}
      aria-label="Email"
    >
      <Icon href={site.links.email} />
    </Button>
    <Button
      variant="ghost"
      size="icon-sm"
      href={site.links.cv}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Download CV"
    >
      <Icon name="file-download" />
    </Button>
    <ThemeToggle />
  </HeaderActions>
</HeaderUI>
